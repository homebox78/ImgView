{
  "name": "imgzipview",
  "version": "0.1.0",
  "description": "ImgZipView - 보고, 편집하고, 압축까지. 이미지 뷰어 · 편집 · 일괄 압축 데스크톱 도구",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "author": "ImgZipView",
  "license": "MIT",
  "build": {
    "appId": "com.imgzipview.app",
    "productName": "ImgZipView",
    "copyright": "© 2026 ImgZipView",
    "artifactName": "ImgZipView-Install-${version}.${ext}",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "license": "license_ko.txt",
      "language": "1042",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "installerSidebar": "installerSidebar.bmp",
      "uninstallerSidebar": "installerSidebar.bmp",
      "installerHeader": "installerHeader.bmp",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": false,
      "shortcutName": "ImgZipView",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "uninstallDisplayName": "ImgZipView ${version}",
      "include": "build/installer.nsh"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "icon.png",
      "icon.ico",
      "fonts/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1"
  }
}
